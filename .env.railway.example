# Jack Core Railway pilot variables.
# Copy these into Railway Variables. Do not commit real secret values.

NODE_ENV=production
BASE_PATH=/
PUBLIC_SITE_URL=https://jack.torchlabs.ca

VITE_CLERK_PUBLISHABLE_KEY=pk_...
VITE_DISABLE_CLERK_PROXY=true
# Leave unset unless you intentionally want Jack to proxy Clerk through /api/__clerk.
VITE_ENABLE_CLERK_PROXY=false
CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
ADMIN_EMAILS=admin@example.com

# Immediate, idempotent user-test feedback alerts. The Review tab remains the
# authoritative record if delivery fails.
RESEND_API_KEY=re_...
FEEDBACK_FROM_EMAIL=Jack Feedback <feedback@your-verified-domain.example>
FEEDBACK_NOTIFICATION_RECIPIENTS=derek@torchlabs.ca

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_DB_URL=postgresql://...

OPENAI_API_KEY=sk-...
